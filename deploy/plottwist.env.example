# Production environment for the Azure VM — copy to /opt/plottwist/.env,
# `chmod 600`, owned by the plottwist user. This is read by systemd
# (EnvironmentFile), which parses KEY=VALUE literally: no quotes, no shell
# expansion. Never commit the real file.

MONGODB_URI=your_atlas_connection_string
CLIENT_ORIGIN=https://plottwist.dylanglover.com
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
PORT=3000

# The server binds to 127.0.0.1 in production by default (it sits behind Caddy
# on the same box). Only set HOST if you know you need a different bind address.
# HOST=127.0.0.1

# --- Optional email notifications (Resend) ---
# Leave RESEND_API_KEY unset to keep email disabled (the app still runs).
# If you enable it, APP_URL MUST be the public origin so email links are correct.
# RESEND_API_KEY=
# EMAIL_FROM=Plot Twist <updates@dylanglover.com>
# APP_URL=https://plottwist.dylanglover.com
# TASKS_SECRET=
