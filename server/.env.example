# Copy this file to server/.env and fill in real values.
# server/.env is gitignored and must never be committed.

# Port the Express API listens on. Dev default is 5050 because macOS AirPlay
# Receiver occupies 5000; the Vite dev proxy targets 5050 to match.
PORT=5050

# Allowed browser origin for CORS in development (the Vite dev server).
# In production, set this to your deployed site's origin.
CLIENT_ORIGIN=http://localhost:5173

# MongoDB connection string (local mongod or a MongoDB Atlas SRV URI). Required.
MONGODB_URI=mongodb://127.0.0.1:27017/plot-twist

# Unsplash API access key for the image search proxy. Optional — without it,
# image search returns an empty result set with a helpful message.
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# --- Email notifications (optional) ---
# Resend API key. Without it, all email is a logged no-op and the app still
# works — the optional email-updates feature is simply inactive.
RESEND_API_KEY=

# From header for outgoing mail. Use a verified domain in production; for
# testing, Resend's onboarding sender works: "Plot Twist <onboarding@resend.dev>"
EMAIL_FROM=Plot Twist <onboarding@resend.dev>

# Public base URL used to build confirm/unsubscribe/reveal links inside emails.
APP_URL=http://localhost:5173

# Shared secret for POST /api/tasks/notifications, so an external cron can drive
# the notification sweep on hosts that sleep idle instances. Optional.
TASKS_SECRET=

# NODE_ENV is normally set by your host or the `npm start` script, not here.
# When "production", the server also serves the built client from client/dist.
# NODE_ENV=production
